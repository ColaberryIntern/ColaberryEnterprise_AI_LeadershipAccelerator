NODE_ENV=production
PORT=3001

# Database (use Docker service name "postgres" as host)
DB_USER=accelerator
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=accelerator_prod
DATABASE_URL=postgres://accelerator:CHANGE_ME_strong_password_here@postgres:5432/accelerator_prod

# PaySimple (production keys)
PAYSIMPLE_API_USER=your-live-api-user
PAYSIMPLE_API_KEY=your-live-api-key
PAYSIMPLE_ENV=live
PAYSIMPLE_WEBHOOK_SECRET=your-webhook-secret
PAYMENT_MODE=live

# JWT
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRES_IN=4h

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=enrollment@colaberry.com

# Synthflow Voice AI
SYNTHFLOW_API_KEY=your-synthflow-api-key
SYNTHFLOW_WELCOME_AGENT_ID=your-welcome-agent-model-id
SYNTHFLOW_INTEREST_AGENT_ID=your-interest-agent-model-id

# Feature Flags
ENABLE_VOICE_CALLS=true
ENABLE_VOICE_CALL_FOR_OVERVIEW=false
ENABLE_AUTO_EMAIL=true
ENABLE_HIGH_INTENT_ALERT=true

# OpenAI (for Intelligence OS)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Intelligence Engine
INTELLIGENCE_ENGINE_URL=http://intelligence:5000

# App (change to your domain when available)
FRONTEND_URL=http://95.216.199.47:8888
