# Dev Environment — experimental features enabled
# Copy secrets from .env on the server (not stored in git)

NODE_ENV=development
APP_ENV=dev
PORT=3001

# Feature Flags (dev-only)
ENABLE_EXPERIMENTAL_FEATURES=true
ENABLE_CONTEXT_GRAPH_V2=true
ENABLE_EXECUTION_ENGINE=true

# Database — reuse production DB
DB_USER=accelerator
DB_NAME=accelerator_prod
# DB_PASSWORD set on server only

# JWT
JWT_EXPIRES_IN=4h

# Note: Copy remaining secrets (API keys, SMTP, etc.) from .env on the VPS
# This file is committed to git as a template — secrets are NOT included
