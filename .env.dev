# Dev Environment — experimental features enabled
# Copy secrets from .env on the server (not stored in git)

NODE_ENV=development
APP_ENV=dev
PORT=3001

# Feature Flags (dev-only)
ENABLE_EXPERIMENTAL_FEATURES=true
ENABLE_CONTEXT_GRAPH_V2=true
ENABLE_EXECUTION_ENGINE=true

# Database — reuse production DB
DB_USER=accelerator
DB_NAME=accelerator_prod
# DB_PASSWORD set on server only

# JWT
JWT_EXPIRES_IN=4h

# Note: Copy remaining secrets (API keys, SMTP, etc.) from .env on the VPS
# This file is committed to git as a template — secrets are NOT included

OPENAI_API_KEY=
BASECAMP_ACCESS_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Cora KB Google Sheets sync (syncCoraKbFromSheets.ts)
# Service-account key file — keep in credentials/ which is .gitignored, never commit.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/micro-environs-434113-p8-57a426b26077.json
CORA_KB_SPREADSHEET_ID=1C69lDig4CoCnqqlAe_8_75eEg8PiPOaBAgjUWp9Yz_A
CORA_KB_SHEET_NAME=Rubric
# Comma-separated Sub Category values to include. Run --list-cats first to see options.
CORA_KB_SUB_CATEGORIES=AI Build Accelerator
