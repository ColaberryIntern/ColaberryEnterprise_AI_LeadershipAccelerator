# =============================================================================
# backend/.env.example
# =============================================================================
# Copy this file to backend/.env.dev for local development:
#   cp backend/.env.example backend/.env.dev
#
# Fill in the values marked REQUIRED. Anything marked OPTIONAL can be left
# blank for local dev; the corresponding feature simply will not run.
#
# NEVER commit a populated .env file. Real values come from Ali or from the
# production VPS at /opt/colaberry-accelerator/.env.
# =============================================================================


# ----- App basics ------------------------------------------------------------
APP_ENV=dev                              # dev | staging | production
PORT=3001
NODE_OPTIONS=--max-old-space-size=512
TZ=America/Chicago


# ----- Database --------------------------------------------------------------
# Local docker-compose defaults; override if you point at a remote DB.
DATABASE_URL=postgres://accelerator:accelerator@accelerator-db:5432/accelerator_prod
PROD_DB_USER=accelerator
PROD_DB_NAME=accelerator_prod
REDIS_URL=redis://accelerator-redis:6379


# ----- URLs ------------------------------------------------------------------
APP_BASE_URL=http://localhost:8888
FRONTEND_URL=http://localhost:8888
BASE_URL=http://localhost:3001
PORTAL_BASE_URL=http://localhost:8888


# ----- Anthropic / OpenAI (REQUIRED for any LLM features) --------------------
OPENAI_API_KEY=
AI_MODEL=gpt-4o
AI_MAX_TOKENS=2000
CHAT_MODEL=gpt-4o-mini
CHAT_MAX_TOKENS=1200
CB_HANDLER_MODEL=gpt-4o
CONTEXTUAL_SUGGESTION_MODEL=gpt-4o-mini


# ----- Basecamp (REQUIRED for any BC integration) ----------------------------
# Token rotates every 2 weeks. Pull current value from CCPP Basecamp_AuthInfo
# table on prod, or ask Ali.
BASECAMP_ACCESS_TOKEN=
BASECAMP_ACCOUNT_ID=3945211
BASECAMP_USER_AGENT=Colaberry
ALI_BC_USER_ID=17454835


# ----- Gmail OAuth (REQUIRED for inbox + email sending features) -------------
# Shared org credentials. Ask Ali for the values.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_COLABERRY_ADDRESS=ali@colaberry.com
ALI_GMAIL=alimuwwakkil@gmail.com


# ----- Mandrill (transactional email) ----------------------------------------
SMTP_HOST=smtp.mandrillapp.com
SMTP_PORT=587
SMTP_USER=ali@colaberry.com
SMTP_PASS=
EMAIL_FROM="Colaberry <ali@colaberry.com>"


# ----- GitHub (OPTIONAL, used by repo-watcher + integrations) ----------------
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
GITHUB_REPO=ColaberryIntern/ColaberryEnterprise_AI_LeadershipAccelerator


# ----- Synthflow voice agent (OPTIONAL) --------------------------------------
SYNTHFLOW_API_KEY=
SYNTHFLOW_WELCOME_AGENT_ID=
SYNTHFLOW_INTEREST_AGENT_ID=


# ----- Apollo / Outreach (OPTIONAL) ------------------------------------------
APOLLO_API_KEY=


# ----- Paysimple (OPTIONAL, payments) ----------------------------------------
PAYSIMPLE_API_USER=
PAYSIMPLE_API_KEY=
PAYSIMPLE_ENV=sandbox
PAYSIMPLE_WEBHOOK_SECRET=
PAYMENT_MODE=test


# ----- Social posting (OPTIONAL) ---------------------------------------------
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
DEVTO_API_KEY=
PRODUCTHUNT_ACCESS_TOKEN=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
DISCOURSE_USERNAME=
DISCOURSE_API_KEY=


# ----- Skool (OPTIONAL) ------------------------------------------------------
SKOOL_COMMUNITY_URL=
SKOOL_EMAIL=
SKOOL_PASSWORD=
SKOOL_DAILY_LIMIT=10
SKOOL_ENABLED=false


# ----- Inbox COS phone-accessible SMS / Hotmail ------------------------------
INBOX_COS_SMS_TO=6825975784@tmomail.net
INBOX_COS_ALERT_GMAIL=alimuwwakkil@gmail.com
ADMIN_ALERT_PHONE=


# ----- Feature flags (defaults for dev) --------------------------------------
ENABLE_CHAT=true
ENABLE_EXECUTION_ENGINE=true
ENABLE_CONTEXT_GRAPH_V2=true
ENABLE_EXPERIMENTAL_FEATURES=true
ENABLE_ARTIFACT_COMPILER=true
ENABLE_ARTIFACT_GRAPH=true
ENABLE_FOLLOWUP_SCHEDULER=false
ENABLE_AUTO_EMAIL=false
ENABLE_VOICE_CALLS=false
ENABLE_VOICE_CALL_FOR_OVERVIEW=false
ENABLE_VISITOR_TRACKING=false
ENABLE_HIGH_INTENT_ALERT=false
ENABLE_REQUIREMENTS_MATCHING=true
AUTONOMOUS_AUTOAPPLY=false


# ----- Ops engine knobs ------------------------------------------------------
OPS_CB_DORMANT_DAYS=30
OPS_STALE_HIDE_DAYS=90


# ----- Preview stacks (OPTIONAL, per-user preview environments) --------------
PREVIEW_STACKS_ROOT=/var/preview-stacks
PREVIEW_PORT_POOL_START=11000
PREVIEW_PORT_POOL_END=11999
PREVIEW_IDLE_TIMEOUT_MS=1800000
PREVIEW_CPU_LIMIT=0.5
PREVIEW_MEM_LIMIT=512m
PREVIEW_PROXY_HOST=host.docker.internal
PREVIEW_BOOT_WAIT_MS=15000


# ----- Misc ------------------------------------------------------------------
UPLOAD_DIR=/var/uploads
DRY_RUN=false
VERBOSE=false
SYSTEM_MODE=normal


# =============================================================================
# DO NOT COMMIT THIS FILE WITH REAL VALUES.
# .env.dev is already in .gitignore. Verify with: git check-ignore backend/.env.dev
# =============================================================================
