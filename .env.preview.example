# Template for preview stack environment variables.
# Copy to .env.preview at provision time; values only need to be safe stubs
# since the preview stack is isolated from production services.
#
# Real secrets (OpenAI, Stripe, SMTP) should NEVER be included here.
# The preview is for UI/UX iteration, not for exercising paid APIs.

NODE_ENV=preview
PORT=3001

# DB — driven by compose; DATABASE_URL is injected by docker-compose.preview.yml
DB_USER=accelerator
DB_PASSWORD=accelerator
DB_NAME=accelerator_preview

# JWT / session — any stable random string for the preview instance
JWT_SECRET=preview-jwt-secret-change-me-per-stack

# Third-party APIs — stubbed so preview boots without real credentials
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Feature flags
DISABLE_EMAIL_SEND=true
DISABLE_STRIPE_WEBHOOKS=true
