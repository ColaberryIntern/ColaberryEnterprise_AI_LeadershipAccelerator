# Intelligence OS Environment Variables
OPENAI_API_KEY=sk-...
DATABASE_URL=postgres://user:pass@localhost:5432/colaberry

# LLM Settings
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# Embedding Settings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Flask
FLASK_ENV=development
FLASK_PORT=5000

# Redis (optional)
REDIS_URL=redis://localhost:6379/1

# Token Budgets
MAX_CONTEXT_TOKENS=8000
SQL_TIMEOUT=10s

# ML Settings
ML_ANOMALY_CONTAMINATION=0.1
ML_FORECAST_PERIODS=90
ML_CLUSTER_MIN_SIZE=5
ML_XGBOOST_ESTIMATORS=100
ML_XGBOOST_DEPTH=6

# Risk Thresholds
RISK_CRITICAL_THRESHOLD=80
RISK_HIGH_THRESHOLD=60
RISK_MEDIUM_THRESHOLD=40
