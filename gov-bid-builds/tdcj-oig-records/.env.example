# ---------- App ----------
NODE_ENV=development
PORT=3000
PUBLIC_URL=https://tdcj-rms-demo.colaberry.dev

# ---------- Database ----------
DATABASE_URL=postgres://tdcj-oig-records:dev@localhost:5432/tdcj_oig_records

# ---------- Object storage ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=tdcj-oig-records-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ---------- Auth ----------
AUTH_SECRET=replace_with_32_char_random_string
AUTH_PROVIDER=mock

# ---------- Email (mock for demo) ----------
EMAIL_PROVIDER=mock
EMAIL_FROM="TDCJ-OIG Records Management System <demo@tdcj-rms-demo.colaberry.dev>"

# ---------- Demo seeding ----------
SEED_RESET=true
SEED_USER_COUNT=20
